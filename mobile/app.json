{
  "expo": {
    "name": "DeenyAI",
    "slug": "deenyai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "deenyai",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D7377"
    },
    "android": {
      "backgroundColor": "#0D7377",
      "package": "com.deenyai.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0bfe4b5f-5bb6-47f9-bdd0-9d0c1656e1f7"
      }
    }
  }
}
